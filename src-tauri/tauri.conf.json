{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Nosbor Map Editor",
	"version": "0.1.0",
	"identifier": "com.nosbor.map-editor",
	"build": {
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build",
		"devUrl": "http://localhost:5180",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Nosbor Map Editor",
				"width": 1300,
				"height": 800,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"decorations": false,
				"transparent": true,
				"shadow": false,
				"dragDropEnabled": false,
				"backgroundColor": [0, 0, 0, 0]
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
	}
}
