{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Map Forge",
	"version": "0.1.0",
	"identifier": "com.frenvius.mapforge",
	"build": {
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build",
		"devUrl": "http://localhost:5180",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Map Forge",
				"width": 1300,
				"height": 800,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"decorations": false,
				"transparent": true,
				"shadow": false,
				"dragDropEnabled": false,
				"backgroundColor": [0, 0, 0, 0]
			}
		],
		"withGlobalTauri": true,
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": ["nsis"],
		"windows": {
			"nsis": {
				"installerIcon": "icons/icon.ico",
				"installMode": "currentUser"
			}
		},
		"resources": {
			"../data/scripts/": "data/scripts/"
		},
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBM0Y2NzM2MjI0OThBNjgKUldSb2lra2lObWMvV3B1MUdmWXdlbDc4YkVLWHlOMFREMlJnTEZmN200dXlJekV1bHdwK2ZDL0YK",
			"endpoints": ["https://raw.githubusercontent.com/Frenvius/map-forge/master/public/updater.json"]
		}
	}
}
